# ===========================
# Uncensored Studio – env vars
# ===========================
# Copy to .env.local and fill in. Never commit .env.local.

# --- App ---
NEXT_PUBLIC_APP_NAME="Uncensored Studio"
NEXT_PUBLIC_APP_URL="http://localhost:6677"
# When deploying to Vercel, set this to your production domain, e.g. https://studio.example.com

# --- Auth (NextAuth.js v5) ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-please"

# --- Database (Prisma) ---
# Local dev (SQLite): file:./prisma/dev.db
# Production (Neon Postgres): postgresql://user:password@ep-xxx.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://localhost:5432/uncensored?schema=public"

# --- Email magic link (Resend) ---
# Free tier: 3000 emails/month, https://resend.com
# For local dev without sending email, leave blank and use AUTH_DEV_PRINT_LINKS=true
RESEND_API_KEY=""
AUTH_EMAIL_FROM="login@uncensored.example"
AUTH_DEV_PRINT_LINKS="true"  # Prints magic link to server console instead of sending email

# --- Inference (GPU backend) ---
# Set to "local" to use ComfyUI on localhost:8188 (dev),
# or "runpod" to use RunPod Serverless (production).
INFERENCE_PROVIDER="local"

# Local-only (when INFERENCE_PROVIDER=local)
COMFY_URL="http://127.0.0.1:8188"

# RunPod Serverless (when INFERENCE_PROVIDER=runpod)
RUNPOD_API_KEY=""
RUNPOD_ENDPOINT_ID=""   # e.g. abc123-comfy-sdxl

# --- Object storage (Cloudflare R2) ---
# Set to "local" to write outputs to ./data/outputs/ (dev only — Vercel can't persist!)
STORAGE_PROVIDER="local"

R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="uncensored-studio"
R2_PUBLIC_URL=""        # e.g. https://cdn.uncensored.example  (Cloudflare public bucket OR custom CDN)

# --- Payment: NowPayments (crypto) ---
# https://nowpayments.io
NOWPAYMENTS_API_KEY=""
NOWPAYMENTS_IPN_SECRET=""
NOWPAYMENTS_SUCCESS_URL="http://localhost:6677/dashboard?payment=success"
NOWPAYMENTS_CANCEL_URL="http://localhost:6677/pricing?payment=cancel"

# --- Payment: Paddle Billing (cards / Apple Pay / etc.) ---
# Add when you've registered a company and Paddle approves your account.
# Leave blank for now → /api/checkout/paddle returns 503, UI shows "Paddle 待上线".
PADDLE_API_KEY=""
PADDLE_WEBHOOK_SECRET=""
PADDLE_ENV="live"            # "sandbox" or "live"

# Paddle price IDs (create in Paddle dashboard → Catalog → Prices, paste pri_xxx here)
PADDLE_PRICE_STARTER_MONTHLY=""
PADDLE_PRICE_PRO_MONTHLY=""
PADDLE_PRICE_STUDIO_MONTHLY=""
PADDLE_PRICE_TOPUP_SMALL=""
PADDLE_PRICE_TOPUP_MEDIUM=""
PADDLE_PRICE_TOPUP_LARGE=""
PADDLE_PRICE_TOPUP_XL=""

# --- Pricing plan IDs ---
# Internal SKU ids that map to Paddle products / NowPayments price points.
# Update these in lib/plans.ts.

# --- Moderation (future) ---
# NSFW_DETECTOR_URL=""
# CELEBRITY_DENY_LIST_URL=""
# C2PA_SIGNING_KEY=""

# --- Admin ---
ADMIN_EMAILS="you@example.com"  # Comma-separated. These users can see /admin (future).
