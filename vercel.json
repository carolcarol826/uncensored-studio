{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "prisma generate && prisma db push --accept-data-loss --skip-generate && next build",
  "framework": "nextjs",
  "regions": ["iad1"],
  "functions": {
    "app/api/generate/route.ts": { "maxDuration": 60 },
    "app/api/status/route.ts": { "maxDuration": 60 },
    "app/api/webhooks/nowpayments/route.ts": { "maxDuration": 30 }
  }
}
