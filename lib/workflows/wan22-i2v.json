{
  "_comment": "Wan 2.2 I2V minimal template. Requires ComfyUI-WanVideoWrapper (Kijai). Adjust node IDs to match the installed version of the wrapper.",
  "1": {
    "inputs": { "model": "__CKPT__", "base_precision": "fp8_e4m3fn", "quantization": "disabled", "load_device": "main_device", "attention_mode": "sdpa" },
    "class_type": "WanVideoModelLoader",
    "_meta": { "title": "Wan Model Loader" }
  },
  "2": {
    "inputs": { "image": "__INPUT_IMAGE__", "upload": "image" },
    "class_type": "LoadImage",
    "_meta": { "title": "Load Image" }
  },
  "3": {
    "inputs": { "model_name": "umt5_xxl_fp8_e4m3fn_scaled.safetensors", "precision": "fp16", "load_device": "offload_device" },
    "class_type": "LoadWanVideoT5TextEncoder",
    "_meta": { "title": "T5 Loader" }
  },
  "4": {
    "inputs": { "positive_prompt": "__POSITIVE__", "negative_prompt": "__NEGATIVE__", "t5": ["3", 0] },
    "class_type": "WanVideoTextEncode",
    "_meta": { "title": "Encode" }
  },
  "5": {
    "inputs": { "model": ["1", 0], "image_embeds": ["6", 0], "text_embeds": ["4", 0], "steps": 20, "cfg": 6, "seed": 0, "scheduler": "unipc", "shift": 5 },
    "class_type": "WanVideoSampler",
    "_meta": { "title": "Sampler" }
  },
  "6": {
    "inputs": { "image": ["2", 0], "width": 832, "height": 480, "num_frames": 81, "model": ["1", 0] },
    "class_type": "WanVideoImageToVideoEncode",
    "_meta": { "title": "I2V Encode" }
  },
  "7": {
    "inputs": { "samples": ["5", 0], "model": ["1", 0] },
    "class_type": "WanVideoDecode",
    "_meta": { "title": "Decode" }
  },
  "8": {
    "inputs": { "images": ["7", 0], "frame_rate": 16, "filename_prefix": "uncensored-studio/wan-i2v", "format": "video/h264-mp4", "save_metadata": true, "crf": 19 },
    "class_type": "VHS_VideoCombine",
    "_meta": { "title": "Save Video" }
  }
}
