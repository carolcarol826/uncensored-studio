{
  "_comment": "PuLID-SDXL 角色一致性，最稳的 8GB VRAM 方案。需要 ComfyUI_PuLID 节点（如 cubiq/sipie800 实现）+ pulid_ip.pulid_v1.bin。",
  "1": {
    "inputs": { "ckpt_name": "__CKPT__" },
    "class_type": "CheckpointLoaderSimple",
    "_meta": { "title": "SDXL Checkpoint" }
  },
  "2": {
    "inputs": { "image": "__INPUT_IMAGE__", "upload": "image" },
    "class_type": "LoadImage",
    "_meta": { "title": "参考脸" }
  },
  "3": {
    "inputs": { "pulid_file": "ip-adapter_pulid_sdxl_fp16.safetensors" },
    "class_type": "PulidModelLoader",
    "_meta": { "title": "PuLID Model" }
  },
  "4": {
    "inputs": {},
    "class_type": "PulidEvaClipLoader",
    "_meta": { "title": "EVA-CLIP" }
  },
  "5": {
    "inputs": { "provider": "CUDA" },
    "class_type": "PulidInsightFaceLoader",
    "_meta": { "title": "InsightFace" }
  },
  "6": {
    "inputs": {
      "model": ["1", 0],
      "pulid": ["3", 0],
      "eva_clip": ["4", 0],
      "face_analysis": ["5", 0],
      "image": ["2", 0],
      "method": "fidelity",
      "weight": 0.95,
      "start_at": 0,
      "end_at": 1
    },
    "class_type": "ApplyPulid",
    "_meta": { "title": "Apply PuLID" }
  },
  "7": {
    "inputs": { "text": "__POSITIVE__", "clip": ["1", 1] },
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Positive" }
  },
  "8": {
    "inputs": { "text": "__NEGATIVE__", "clip": ["1", 1] },
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Negative" }
  },
  "9": {
    "inputs": { "width": 1024, "height": 1024, "batch_size": 1 },
    "class_type": "EmptyLatentImage",
    "_meta": { "title": "Latent" }
  },
  "10": {
    "inputs": {
      "seed": 0,
      "steps": 25,
      "cfg": 7,
      "sampler_name": "dpmpp_2m_sde",
      "scheduler": "karras",
      "denoise": 1.0,
      "model": ["6", 0],
      "positive": ["7", 0],
      "negative": ["8", 0],
      "latent_image": ["9", 0]
    },
    "class_type": "KSampler",
    "_meta": { "title": "Sampler" }
  },
  "11": {
    "inputs": { "samples": ["10", 0], "vae": ["1", 2] },
    "class_type": "VAEDecode",
    "_meta": { "title": "Decode" }
  },
  "12": {
    "inputs": { "filename_prefix": "uncensored-studio/pulid-sdxl", "images": ["11", 0] },
    "class_type": "SaveImage",
    "_meta": { "title": "Save" }
  }
}
